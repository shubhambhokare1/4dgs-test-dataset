<mujoco model="scene8_thin_structure">
  <compiler angle="radian"/>
  
  <option timestep="0.002" gravity="0 0 -9.81">
    <flag contact="disable"/>
  </option>

  <visual>
    <global offwidth="800" offheight="800"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture name="white_skybox"
             type="skybox"
             builtin="flat"
             width="512"
             height="512"
             rgb1="1 1 1"
             rgb2="1 1 1"/>
    <material name="white_floor" rgba="1 1 1 1" reflectance="0"/>
  </asset>

  <worldbody>
    <light directional="true" pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light directional="true" pos="2 2 3" dir="-0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>
    
    <geom name="floor" type="plane" size="5 5 0.1" material="white_floor" pos="0 0 -0.5"/>
    
    <body name="target" pos="0 0 1.0">
      <site name="target_site" size="0.01" rgba="1 0 0 0"/>
    </body>
    
    <!-- Moving rod (red, moves left to right) -->
    <body name="rod_moving" pos="-2.0 -0.5 1.0">
      <freejoint/>
      <geom name="rod_moving_geom" type="cylinder" size="0.04 1.0" rgba="0.9 0.2 0.2 1" mass="1"/>
    </body>
    
    <!-- Rotating rod (blue, spins in place) -->
    <body name="rod_rotating" pos="0 0.5 2.0">
      <freejoint/>
      <geom name="rod_rotating_geom" type="cylinder" size="0.08 1.0" rgba="0.2 0.2 0.9 1" mass="1"/>
    </body>

    <!-- Scaled 1.7x for 800x800 square resolution — moving rod extends ±2.5m from target -->
    <camera name="cam0" pos="5.1 0 2.55" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam1" pos="0 5.1 2.55" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam2" pos="-5.1 0 2.55" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam3" pos="0 -5.1 2.55" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam4" pos="4.25 4.25 4.25" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam5" pos="-4.25 4.25 4.25" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam6" pos="4.25 -4.25 4.25" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam7" pos="-4.25 -4.25 4.25" mode="targetbody" target="target" fovy="50"/>
    <camera name="cam8" pos="3.4 0 1.36" mode="targetbody" target="target" fovy="55"/>
    <camera name="cam9" pos="-3.4 0 1.36" mode="targetbody" target="target" fovy="55"/>
    <camera name="cam10" pos="0 0 6.0" mode="targetbody" target="target" fovy="45"/>
    <camera name="cam11" pos="2.55 2.55 5.1" mode="targetbody" target="target" fovy="45"/>
  </worldbody>
</mujoco>